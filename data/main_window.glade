<?xml version="1.0" encoding="UTF-8"?>
<!-- SimpleAutoFramer — main window layout.
     Structure (no GtkPaned):
       GtkWindow
         ├── GtkHeaderBar (titlebar)
         └── GtkBox (horizontal)
              ├── video area (hexpand=TRUE)      — takes remaining space
              └── sidebar scrolled window (width-request=360, hexpand=FALSE)
     The sidebar stays at 360 px; the video slot grows/shrinks with the
     window, so dragging the edge always resizes the video, no stuck-max
     behaviour. -->
<interface>
  <requires lib="gtk+" version="3.24"/>

  <!-- ==================================================================
       Shared adjustments
       ================================================================== -->
  <object class="GtkAdjustment" id="adj_zoom_base">
    <property name="lower">1.0</property>
    <property name="upper">3.0</property>
    <property name="value">1.5</property>
    <property name="step-increment">0.05</property>
    <property name="page-increment">0.5</property>
  </object>
  <object class="GtkAdjustment" id="adj_zoom_multiplier">
    <property name="lower">0.0</property>
    <property name="upper">5.0</property>
    <property name="value">1.0</property>
    <property name="step-increment">0.1</property>
    <property name="page-increment">0.5</property>
  </object>
  <object class="GtkAdjustment" id="adj_smoothing">
    <property name="lower">0.0</property>
    <property name="upper">1.0</property>
    <property name="value">0.5</property>
    <property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_confidence">
    <property name="lower">0.0</property>
    <property name="upper">1.0</property>
    <property name="value">0.5</property>
    <property name="step-increment">0.01</property>
    <property name="page-increment">0.1</property>
  </object>
  <object class="GtkAdjustment" id="adj_width">
    <property name="lower">320</property>
    <property name="upper">3840</property>
    <property name="value">1280</property>
    <property name="step-increment">1</property>
    <property name="page-increment">10</property>
  </object>
  <object class="GtkAdjustment" id="adj_height">
    <property name="lower">240</property>
    <property name="upper">2160</property>
    <property name="value">720</property>
    <property name="step-increment">1</property>
    <property name="page-increment">10</property>
  </object>

  <!-- ==================================================================
       Popover menu (hamburger in the HeaderBar)
       ================================================================== -->
  <object class="GtkMenu" id="app_menu">
    <property name="visible">True</property>
    <child>
      <object class="GtkMenuItem" id="new_profile">
        <property name="visible">True</property>
        <property name="label" translatable="yes">New profile…</property>
      </object>
    </child>
    <child>
      <object class="GtkMenuItem" id="delete_profile">
        <property name="visible">True</property>
        <property name="label" translatable="yes">Delete profile</property>
      </object>
    </child>
    <child>
      <object class="GtkSeparatorMenuItem">
        <property name="visible">True</property>
      </object>
    </child>
    <child>
      <object class="GtkMenuItem" id="doc_menu_item">
        <property name="visible">True</property>
        <property name="label" translatable="yes">Documentation</property>
      </object>
    </child>
    <child>
      <object class="GtkMenuItem" id="about_menu_item">
        <property name="visible">True</property>
        <property name="label" translatable="yes">About SimpleAutoFramer</property>
      </object>
    </child>
  </object>

  <!-- ==================================================================
       Main window
       ================================================================== -->
  <object class="GtkWindow" id="main_window">
    <property name="can-focus">False</property>
    <property name="default-width">1280</property>
    <property name="default-height">780</property>
    <property name="icon-name">camera-photo</property>
    <style>
      <class name="saf-root"/>
    </style>

    <child type="titlebar">
      <object class="GtkHeaderBar" id="saf_header">
        <property name="visible">True</property>
        <property name="show-close-button">True</property>
        <property name="title">SimpleAutoFramer</property>
        <property name="subtitle">Auto-framing for your webcam</property>
        <style>
          <class name="saf-header"/>
        </style>

        <!-- left: hamburger + live dot -->
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="spacing">8</property>
            <child>
              <object class="GtkMenuButton" id="menu_button">
                <property name="visible">True</property>
                <property name="focus-on-click">False</property>
                <property name="popup">app_menu</property>
                <property name="tooltip-text" translatable="yes">Menu</property>
                <child>
                  <object class="GtkImage">
                    <property name="visible">True</property>
                    <property name="icon-name">open-menu-symbolic</property>
                  </object>
                </child>
                <style>
                  <class name="image-button"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property name="label">●</property>
                <property name="tooltip-text" translatable="yes">Virtual camera status</property>
                <style>
                  <class name="saf-live-dot"/>
                </style>
              </object>
            </child>
          </object>
        </child>

        <!-- right: profile picker -->
        <child>
          <object class="GtkBox">
            <property name="visible">True</property>
            <property name="spacing">6</property>
            <property name="margin-start">4</property>
            <property name="margin-end">4</property>
            <style>
              <class name="saf-header-profile"/>
            </style>
            <child>
              <object class="GtkLabel">
                <property name="visible">True</property>
                <property name="label" translatable="yes">PROFILE</property>
                <style>
                  <class name="dim-label"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkComboBoxText" id="profile_box">
                <property name="visible">True</property>
                <property name="tooltip-text" translatable="yes">Switch profile</property>
                <property name="width-request">160</property>
              </object>
            </child>
          </object>
          <packing>
            <property name="pack-type">end</property>
          </packing>
        </child>
      </object>
    </child>

    <!-- =================================================================
         Main content: horizontal box, video + sidebar.
         ================================================================= -->
    <child>
      <object class="GtkBox" id="main_content">
        <property name="visible">True</property>
        <property name="orientation">horizontal</property>
        <property name="spacing">0</property>

        <!-- ============ Video slot (expands) ============ -->
        <child>
          <object class="GtkBox" id="video_container">
            <property name="visible">True</property>
            <property name="orientation">vertical</property>
            <property name="hexpand">True</property>
            <property name="vexpand">True</property>
            <property name="margin-top">16</property>
            <property name="margin-bottom">16</property>
            <property name="margin-start">16</property>
            <property name="margin-end">8</property>
            <child>
              <object class="GtkFrame">
                <property name="visible">True</property>
                <property name="hexpand">True</property>
                <property name="vexpand">True</property>
                <property name="shadow-type">none</property>
                <property name="label-xalign">0</property>
                <style>
                  <class name="saf-card"/>
                  <class name="saf-video-card"/>
                </style>
                <child type="label_item">
                  <placeholder/>
                </child>
                <child>
                  <object class="GtkBox" id="video_slot">
                    <property name="visible">True</property>
                    <property name="orientation">vertical</property>
                    <property name="halign">center</property>
                    <property name="valign">center</property>
                    <property name="hexpand">True</property>
                    <property name="vexpand">True</property>
                    <child>
                      <object class="GtkImage" id="video_image">
                        <property name="visible">True</property>
                        <property name="can-focus">False</property>
                        <property name="halign">center</property>
                        <property name="valign">center</property>
                        <property name="icon-name">camera-web-symbolic</property>
                        <property name="pixel-size">96</property>
                        <property name="use-fallback">True</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
          <packing>
            <property name="expand">True</property>
            <property name="fill">True</property>
          </packing>
        </child>

        <!-- ============ Sidebar (fixed 360 px) ============ -->
        <child>
          <object class="GtkScrolledWindow">
            <property name="visible">True</property>
            <property name="hscrollbar-policy">never</property>
            <property name="vscrollbar-policy">automatic</property>
            <property name="shadow-type">none</property>
            <property name="width-request">360</property>
            <property name="hexpand">False</property>
            <property name="vexpand">True</property>
            <style>
              <class name="saf-sidebar"/>
            </style>
            <child>
              <object class="GtkBox">
                <property name="visible">True</property>
                <property name="orientation">vertical</property>
                <property name="spacing">14</property>
                <property name="margin-top">16</property>
                <property name="margin-bottom">16</property>
                <property name="margin-start">8</property>
                <property name="margin-end">16</property>

                <!-- ===== Detection ===== -->
                <child>
                  <object class="GtkFrame">
                    <property name="visible">True</property>
                    <property name="shadow-type">none</property>
                    <property name="label-xalign">0</property>
                    <style><class name="saf-card"/></style>
                    <child type="label">
                      <object class="GtkLabel">
                        <property name="visible">True</property>
                        <property name="label" translatable="yes">DETECTION</property>
                        <style><class name="saf-section-title"/></style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkGrid">
                        <property name="visible">True</property>
                        <property name="row-spacing">10</property>
                        <property name="column-spacing">12</property>
                        <property name="margin-top">14</property>
                        <property name="margin-bottom">14</property>
                        <property name="margin-start">14</property>
                        <property name="margin-end">14</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="label" translatable="yes">Model</property>
                            <property name="halign">start</property>
                            <style><class name="dim-label"/></style>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                        </child>
                        <child>
                          <object class="GtkComboBoxText" id="model_selection">
                            <property name="visible">True</property>
                            <property name="hexpand">True</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="label" translatable="yes">Confidence</property>
                            <property name="halign">start</property>
                            <style><class name="dim-label"/></style>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                        </child>
                        <child>
                          <object class="GtkScale" id="detection_confidence">
                            <property name="visible">True</property>
                            <property name="hexpand">True</property>
                            <property name="adjustment">adj_confidence</property>
                            <property name="digits">2</property>
                            <property name="draw-value">True</property>
                            <property name="value-pos">right</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>

                <!-- ===== Framing ===== -->
                <child>
                  <object class="GtkFrame">
                    <property name="visible">True</property>
                    <property name="shadow-type">none</property>
                    <property name="label-xalign">0</property>
                    <style><class name="saf-card"/></style>
                    <child type="label">
                      <object class="GtkLabel">
                        <property name="visible">True</property>
                        <property name="label" translatable="yes">FRAMING</property>
                        <style><class name="saf-section-title"/></style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkGrid">
                        <property name="visible">True</property>
                        <property name="row-spacing">10</property>
                        <property name="column-spacing">12</property>
                        <property name="margin-top">14</property>
                        <property name="margin-bottom">14</property>
                        <property name="margin-start">14</property>
                        <property name="margin-end">14</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="label" translatable="yes">Zoom base</property>
                            <property name="halign">start</property>
                            <style><class name="dim-label"/></style>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                        </child>
                        <child>
                          <object class="GtkScale" id="zoom_base">
                            <property name="visible">True</property>
                            <property name="hexpand">True</property>
                            <property name="adjustment">adj_zoom_base</property>
                            <property name="digits">2</property>
                            <property name="draw-value">True</property>
                            <property name="value-pos">right</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">0</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="label" translatable="yes">Zoom multiplier</property>
                            <property name="halign">start</property>
                            <style><class name="dim-label"/></style>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                        </child>
                        <child>
                          <object class="GtkScale" id="zoom_multiplier">
                            <property name="visible">True</property>
                            <property name="hexpand">True</property>
                            <property name="adjustment">adj_zoom_multiplier</property>
                            <property name="digits">2</property>
                            <property name="draw-value">True</property>
                            <property name="value-pos">right</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">1</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="label" translatable="yes">Smoothing</property>
                            <property name="halign">start</property>
                            <style><class name="dim-label"/></style>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
                        </child>
                        <child>
                          <object class="GtkScale" id="smoothing_factor">
                            <property name="visible">True</property>
                            <property name="hexpand">True</property>
                            <property name="adjustment">adj_smoothing</property>
                            <property name="digits">2</property>
                            <property name="draw-value">True</property>
                            <property name="value-pos">right</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>

                <!-- ===== Cameras ===== -->
                <child>
                  <object class="GtkFrame">
                    <property name="visible">True</property>
                    <property name="shadow-type">none</property>
                    <property name="label-xalign">0</property>
                    <style><class name="saf-card"/></style>
                    <child type="label">
                      <object class="GtkLabel">
                        <property name="visible">True</property>
                        <property name="label" translatable="yes">CAMERAS</property>
                        <style><class name="saf-section-title"/></style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkGrid">
                        <property name="visible">True</property>
                        <property name="row-spacing">10</property>
                        <property name="column-spacing">12</property>
                        <property name="margin-top">14</property>
                        <property name="margin-bottom">14</property>
                        <property name="margin-start">14</property>
                        <property name="margin-end">14</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="label" translatable="yes">Input</property>
                            <property name="halign">start</property>
                            <style><class name="dim-label"/></style>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">0</property></packing>
                        </child>
                        <child>
                          <object class="GtkComboBoxText" id="camera_selection">
                            <property name="visible">True</property>
                            <property name="hexpand">True</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">0</property><property name="width">3</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="label" translatable="yes">Virtual</property>
                            <property name="halign">start</property>
                            <style><class name="dim-label"/></style>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">1</property></packing>
                        </child>
                        <child>
                          <object class="GtkComboBoxText" id="virtual_camera_selection">
                            <property name="visible">True</property>
                            <property name="hexpand">True</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">1</property><property name="width">3</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="label" translatable="yes">Resolution</property>
                            <property name="halign">start</property>
                            <style><class name="dim-label"/></style>
                          </object>
                          <packing><property name="left-attach">0</property><property name="top-attach">2</property></packing>
                        </child>
                        <child>
                          <object class="GtkSpinButton" id="target_width">
                            <property name="visible">True</property>
                            <property name="hexpand">True</property>
                            <property name="adjustment">adj_width</property>
                            <property name="numeric">True</property>
                          </object>
                          <packing><property name="left-attach">1</property><property name="top-attach">2</property></packing>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="label" translatable="yes">×</property>
                            <property name="halign">center</property>
                            <style><class name="dim-label"/></style>
                          </object>
                          <packing><property name="left-attach">2</property><property name="top-attach">2</property></packing>
                        </child>
                        <child>
                          <object class="GtkSpinButton" id="target_height">
                            <property name="visible">True</property>
                            <property name="hexpand">True</property>
                            <property name="adjustment">adj_height</property>
                            <property name="numeric">True</property>
                          </object>
                          <packing><property name="left-attach">3</property><property name="top-attach">2</property></packing>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>

                <!-- ===== Shortcut ===== -->
                <child>
                  <object class="GtkFrame">
                    <property name="visible">True</property>
                    <property name="shadow-type">none</property>
                    <property name="label-xalign">0</property>
                    <style><class name="saf-card"/></style>
                    <child type="label">
                      <object class="GtkLabel">
                        <property name="visible">True</property>
                        <property name="label" translatable="yes">SHORTCUT</property>
                        <style><class name="saf-section-title"/></style>
                      </object>
                    </child>
                    <child>
                      <object class="GtkBox">
                        <property name="visible">True</property>
                        <property name="orientation">vertical</property>
                        <property name="spacing">6</property>
                        <property name="margin-top">14</property>
                        <property name="margin-bottom">14</property>
                        <property name="margin-start">14</property>
                        <property name="margin-end">14</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="visible">True</property>
                            <property name="label" translatable="yes">Global key combination. Click the keyboard icon (or double-click the field) to capture.</property>
                            <property name="wrap">True</property>
                            <property name="xalign">0</property>
                            <style><class name="dim-label"/></style>
                          </object>
                        </child>
                        <child>
                          <object class="GtkEntry" id="shortcut_entry">
                            <property name="visible">True</property>
                            <property name="hexpand">True</property>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </child>

                <!-- ===== Apply ===== -->
                <child>
                  <object class="GtkButton" id="apply_button">
                    <property name="visible">True</property>
                    <property name="can-focus">True</property>
                    <property name="receives-default">True</property>
                    <property name="label" translatable="yes">APPLY CHANGES</property>
                    <property name="margin-top">4</property>
                    <style>
                      <class name="saf-apply"/>
                    </style>
                  </object>
                </child>

                <!-- ===== Status strip ===== -->
                <child>
                  <object class="GtkLabel" id="status_label">
                    <property name="visible">True</property>
                    <property name="halign">start</property>
                    <property name="xalign">0</property>
                    <property name="label" translatable="yes">● READY · SimpleAutoFramer v0.2</property>
                    <property name="margin-top">8</property>
                    <style>
                      <class name="saf-status"/>
                    </style>
                  </object>
                </child>

              </object>
            </child>
          </object>
          <packing>
            <property name="expand">False</property>
            <property name="fill">True</property>
          </packing>
        </child>
      </object>
    </child>
  </object>
</interface>
